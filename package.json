{
  "name": "sql-cat-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "node ./scripts/run-seed-safe.cjs && tsx watch --tsconfig tsconfig.json src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "prestart": "node ./scripts/run-seed-safe.cjs",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "vitest",
    "seed": "tsx --tsconfig tsconfig.json src/scripts/seed.ts",
    "seed-safe": "node ./scripts/run-seed-safe.cjs"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "mysql2": "^3.20.0",
    "node-sql-parser": "^5.4.0",
    "openai": "^4.0.0",
    "pino": "^9.0.0",
    "uuid": "^11.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.4",
    "@types/uuid": "^10.0.0",
    "eslint": "8.57.0",
    "pino-pretty": "^11.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^1.6.0"
  }
}
