# ─── Database ──────────────────────────────────────────────────────────────────
# Full MySQL connection string. Railway provides this via ${{MySQL.DATABASE_URL}}
DATABASE_URL="mysql://user:password@host:3306/"

# ─── AI Coach (OpenRouter) ─────────────────────────────────────────────────────
OPENROUTER_API_KEY="sk-or-v1-..."
OPENROUTER_MODEL="anthropic/claude-3.5-sonnet"
# Set to your deployed frontend URL in production
OPENROUTER_HTTP_REFERER="https://your-frontend.up.railway.app"

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Set to your frontend URL in production.
# Leave blank to allow all origins (not recommended for production).
CORS_ORIGIN="https://your-frontend.up.railway.app"
